# --- LLM providers (set whichever you have) ---
# Groq (free, fast Llama 3 70B + Whisper):  https://console.groq.com/keys
GROQ_API_KEY=
# Gemini (free tier):                       https://aistudio.google.com/apikey
GOOGLE_API_KEY=


# --- Model preferences ---
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
DEFAULT_MODEL=auto

# --- Embedding model (multilingual, runs locally on CPU) ---
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Vector DB ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=smarted

# --- PDF / OCR ---
PDF_DIR=./data/pdfs
TESSERACT_LANGS=eng+urd
# On Windows uncomment and set the path to tesseract.exe if not on PATH:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Local Whisper fallback (used if GROQ_API_KEY is missing) ---
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE=int8

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOW_ORIGINS=*
